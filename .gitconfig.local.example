# ローカル Git 設定ファイル
# このファイルを ~/.gitconfig.local にコピーして編集してください
# このファイルはリポジトリで管理されず、bootstrap.sh で上書きされません

[user]
	name = YOUR_NAME
	email = YOUR_EMAIL@example.com

# 以下は必要に応じて追加
# [ghq]
# 	root = ~/workspace

# [credential]
# 	helper = osxkeychain

# [commit]
# 	gpgsign = true

# [user]
# 	signingkey = YOUR_GPG_KEY_ID
